{
  "manifest_version": 3,
  "name": "Urge Guard",
  "version": "0.1.0",
  "description": "Mindful site blocking with emotion tracking",
  "permissions": [
    "storage",
    "webNavigation",
    "tabs"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.svg",
      "96": "icons/icon-96.svg"
    }
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icons/icon-48.svg",
    "96": "icons/icon-96.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "urge-guard@gerlv",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "browsingActivity"
        ],
        "optional": []
      }
    },
    "gecko_android": {
      "strict_min_version": "113.0"
    }
  }
}